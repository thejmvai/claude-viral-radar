# Viral Radar — optional credentials. Copy to your project's `.claude/viral-radar.env`
# (gitignored) and fill in. Never commit the real file.

# Telegram digest (P1) — push a run digest to your phone. See guides/setup-telegram.md.
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=123456789

# yt-dlp media downloads — Instagram now requires an authenticated session. Point yt-dlp at a
# browser profile that is logged into Instagram (yt-dlp --cookies-from-browser syntax), or a
# Netscape cookies.txt. The scheduled refresh defaults to "chrome" automatically.
# VR_YTDLP_COOKIES_FROM_BROWSER=chrome
# VR_YTDLP_COOKIES_FILE=/path/to/cookies.txt
